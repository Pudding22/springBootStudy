<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.mapper.StudentMapper">

    <!-- 查询所有
    <select id="findAll" resultType="org.example.entity.Student">
        SELECT id, stu_no, name, sex, age, class_name, teacher
        FROM student
    </select>
    -->

    <!-- 按ID查询 -->
    <select id="selectById" resultType="org.example.entity.Student">
        SELECT *
        FROM student
        WHERE id = #{id}
    </select>

    <!-- 多条件动态查询 -->
    <select id="selectByCondition" resultType="org.example.entity.Student">
        select * from student
        <where>
            <if test="age != null">
                age &lt; #{age}
            </if>
            <if test="name != null and name != '' ">
                and name like #{name}
            </if>
        </where>
    </select>
    <!-- 单条件动态查询 -->
    <select id="selectByCondition2" resultType="org.example.entity.Student">
        select * from student
        <where>
            <choose>
                <when test="age != null">
                    age = #{age}
                </when>
                <when test="name != null and name != ''">
                    name like #{name}
                </when>
            </choose>
        </where>
    </select>
    <!-- 插入数据 -->
    <insert id="addStudent" useGeneratedKeys="true" keyProperty="id">
        insert into student(stu_no,name,age,sex)
        values(#{stuNo},#{name},#{age},#{sex})
    </insert>

    <update id="updateStudent">
        update student
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="age != null">
                age = #{age},
            </if>
            <if test="classId != null">
                class_id = #{classId}
            </if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteStudent">
        delete from student where id = #{id}
    </delete>

    <delete id="delete2Student">
        delete from student where id
        in
            <foreach collection="ids" item="id" open="(" close=")" separator=",">
                #{id}
            </foreach>
    </delete>








    <!--
    处理多对一的映射关系:
            a>级联属性赋值
               处理多对一映射关系方式一:级联属性赋值
               <resultMap id="empAndDeptResultMapOne" type="Emp">
                   <id property="eid" column="eid"></id>
                   <result property="empName" column="emp_name"></result>
                   <result property="age" column="age"></result>
                   <result property="sex" column="sex"></result>
                   <result property="email" column="email"></result>

                   <result property="dept.did" column="did"></result>
                   <result property="dept.deptName" column="dept_name"></result>

               </resultMap>
            b>association
            c>分步查询

     -->

<!--
    resultMap:设置自定义映射关系
    id:唯一标识，不能重复
    type:设置映射关系中的实体类类型子标签:
    id:设置主键的映射关系
    result:设置普通字段的映射关系属性:
    property:设置映射关系中的属性名，必须是type属性所设置的实体类类型中的属性名
    column:设置映射关系中的字段名，必须是sql语句查询出的字段名

    -->

    <resultMap id="stuResultMap" type="org.example.entity.Student">
        <id property="id" column="s_id"/>
        <result property="stuNo" column="stu_no"/>
        <result property="name" column="s_name"/>
        <result property="age" column="age"/>
        <result property="sex" column="sex"/>
        <result property="classId" column="class_id"/>
        <result property="createTime" column="create_time"/>
        <!--
        association:处理多对一的映射关系,方式②
        property:需要处理多对的映射关系的属性名
        javaType:该属性的类型

        property:当前实体(Student)中的属性名称(private Clazz clazz)
        javaType:当前实体(Student)中的属性的类型(Clazz)

        -->
        <association property="clazz" javaType="org.example.entity.Clazz">
            <id property="id" column="c_id"/>     <!--自闭合-->
            <result property="name" column="c_name"/>
            <result property="grade" column="grade"/>
            <result property="clazz" column="c_clazz"/>
            <result property="teacherId" column="teacher_id"/>
        </association>
    </resultMap>

    <select id="getStuAndClass" resultMap="stuResultMap">
        select
            s.id AS s_id,
            s.stu_no,
            s.name AS s_name,
            s.age,
            s.sex,
            s.class_id,
            s.create_time,
            c.id AS c_id,
            c.name AS c_name,
            c.grade,
            c.clazz AS c_clazz,
            c.teacher_id

            t.name as teacherName

        from student s left join clazz c on s.class_id = c.id
        where s.id = #{id}
    </select>




    <resultMap id="stuHobbyMAp" type="org.example.entity.Student">
        <id property="id" column="id"/>
        <result property="name" column="cname"/>
        <result property="stuNo" column=""/>
        <result property="age" column=""/>
        <result property="sex" column=""/>
        <result property="classId" column=""/>
        <!-- List<Hobby> -->
        <collection property="hobbies" ofType="org.example.entity.Hobby">
            <id property="id" column="hobby.id"/>
            <result property="hName" column="name"/>
        </collection>
    </resultMap>
    
    <select id="getStuAndHobby" resultMap="stuHobbyMAp">
        select *
        from student s,hobby h,s_h sh where s.id = sh.student_id and h.id = sh.hobby.id
    </select>>




</mapper>